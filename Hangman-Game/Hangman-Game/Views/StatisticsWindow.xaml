<Window x:Class="Hangman_Game.Views.StatisticsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Statistics"
        Height="520"
        Width="820"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#120B0B">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>

        <Style TargetType="Button">
            <Setter Property="Foreground" Value="#F7D28D"/>
            <Setter Property="Background" Value="#2A1B1B"/>
            <Setter Property="BorderBrush" Value="#D18A2C"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="Margin" Value="8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#3A2525"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#E3A74B"/>
                            </Trigger>

                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#1E1212"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#C47B1C"/>
                            </Trigger>

                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Background" Value="#241919"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#8A6A3D"/>
                                <Setter Property="Foreground" Value="#C8A977"/>
                                <Setter Property="Opacity" Value="0.85"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#F2D8A7"/>
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="#1E1212"/>
            <Setter Property="Foreground" Value="#F2D8A7"/>
            <Setter Property="BorderBrush" Value="#D18A2C"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="RowBackground" Value="#1E1212"/>
            <Setter Property="AlternatingRowBackground" Value="#241919"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#7A4A2A"/>
            <Setter Property="VerticalGridLinesBrush" Value="#7A4A2A"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="CanUserDeleteRows" Value="False"/>
            <Setter Property="CanUserResizeRows" Value="False"/>
            <Setter Property="CanUserReorderColumns" Value="False"/>
            <Setter Property="CanUserSortColumns" Value="True"/>
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="RowHeight" Value="38"/>
            <Setter Property="ColumnHeaderHeight" Value="42"/>
            <Setter Property="FontSize" Value="15"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#1E1212"/>
            <Setter Property="Foreground" Value="#F7D28D"/>
            <Setter Property="BorderBrush" Value="#D18A2C"/>
            <Setter Property="BorderThickness" Value="0,0,0,2"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="8"/>
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="Background" Value="#1E1212"/>
            <Setter Property="Foreground" Value="#F2D8A7"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#241919"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#3A2525"/>
                    <Setter Property="Foreground" Value="#F7D28D"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="TextBlock.TextAlignment" Value="Center"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Foreground" Value="#F7D28D"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="#1E1212"
                BorderBrush="#D18A2C"
                BorderThickness="2"
                CornerRadius="10"
                Padding="16"
                Margin="0,0,0,18">
            <StackPanel>
                <TextBlock Text="ALL PLAYERS STATISTICS"
                           HorizontalAlignment="Center"
                           FontSize="28"
                           FontWeight="Bold"
                           Foreground="#F7D28D"/>

                <TextBlock Text="Games played and games won for each user and category"
                           HorizontalAlignment="Center"
                           Margin="0,8,0,0"
                           FontSize="14"
                           Foreground="#F2D8A7"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="1"
                Background="#1E1212"
                BorderBrush="#D18A2C"
                BorderThickness="2"
                CornerRadius="10"
                Padding="10">
            <Grid>
                <DataGrid ItemsSource="{Binding Statistics}"
                          AlternationCount="2"
                          SelectionMode="Single"
                          SelectionUnit="FullRow"
                          Visibility="{Binding HasStatistics, Converter={StaticResource BoolToVisibilityConverter}}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="User"
                                            Binding="{Binding Username}"
                                            Width="2*" />
                        <DataGridTextColumn Header="Category"
                                            Binding="{Binding Category}"
                                            Width="2*" />
                        <DataGridTextColumn Header="Games Played"
                                            Binding="{Binding GamesPlayed}"
                                            Width="*" />
                        <DataGridTextColumn Header="Games Won"
                                            Binding="{Binding GamesWon}"
                                            Width="*" />
                    </DataGrid.Columns>
                </DataGrid>

                <StackPanel HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasStatistics}" Value="False">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>

                    <TextBlock Text="No statistics available yet"
                               FontSize="24"
                               FontWeight="Bold"
                               HorizontalAlignment="Center"
                               Foreground="#F7D28D"/>

                    <TextBlock Text="Finish at least one game to see statistics here."
                               Margin="0,10,0,0"
                               FontSize="15"
                               HorizontalAlignment="Center"
                               Foreground="#F2D8A7"/>
                </StackPanel>
            </Grid>
        </Border>

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Margin="0,18,0,0">
            <Button Content="Close"
                    Width="170"
                    Height="44"
                    Command="{Binding CloseCommand}" />
        </StackPanel>
    </Grid>
</Window>