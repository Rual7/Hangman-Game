<Window x:Class="Hangman_Game.Views.InputDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Save Game"
        Height="340"
        Width="540"
        MinHeight="340"
        MinWidth="540"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="#120B0B">

    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Foreground" Value="#F7D28D"/>
            <Setter Property="Background" Value="#2A1B1B"/>
            <Setter Property="BorderBrush" Value="#D18A2C"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="Margin" Value="8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#3A2525"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#E3A74B"/>
                            </Trigger>

                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#1E1212"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#C47B1C"/>
                            </Trigger>

                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Background" Value="#241919"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#8A6A3D"/>
                                <Setter Property="Foreground" Value="#C8A977"/>
                                <Setter Property="Opacity" Value="0.85"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#F2D8A7"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#1A1010"/>
            <Setter Property="Foreground" Value="#F2D8A7"/>
            <Setter Property="BorderBrush" Value="#D18A2C"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="Height" Value="48"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="CaretBrush" Value="#F7D28D"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"/>
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#E3A74B"/>
                            </Trigger>

                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#F0C27B"/>
                                <Setter TargetName="border" Property="Background" Value="#211414"/>
                            </Trigger>

                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Background" Value="#241919"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#8A6A3D"/>
                                <Setter Property="Foreground" Value="#C8A977"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#140B0B" Offset="0"/>
                <GradientStop Color="#261313" Offset="0.5"/>
                <GradientStop Color="#120909" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <Border Margin="18"
                Padding="24"
                Background="#1E1212"
                BorderBrush="#D18A2C"
                BorderThickness="2"
                CornerRadius="12"
                VerticalAlignment="Stretch"
                HorizontalAlignment="Stretch">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="16"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="16"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="20"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="Save Game"
                           FontSize="30"
                           FontWeight="Bold"
                           Foreground="#F0C27B"
                           HorizontalAlignment="Center"/>

                <TextBlock Grid.Row="2"
                           Text="{Binding Message}"
                           FontSize="17"
                           TextWrapping="Wrap"
                           TextAlignment="Center"
                           HorizontalAlignment="Stretch"
                           VerticalAlignment="Center"/>

                <TextBox Grid.Row="4"
                         x:Name="SaveNameTextBox"
                         Text="{Binding InputText, UpdateSourceTrigger=PropertyChanged}"
                         MaxLength="50"
                         HorizontalAlignment="Stretch"
                         VerticalAlignment="Center"/>

                <Grid Grid.Row="6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0"
                            Content="OK"
                            Height="42"
                            MinWidth="100"
                            MaxWidth="150"
                            IsDefault="True"
                            Click="OnOkClicked"/>

                    <Button Grid.Column="2"
                            Content="Cancel"
                            Height="42"
                            MinWidth="100"
                            MaxWidth="150"
                            IsCancel="True"
                            Click="OnCancelClicked"/>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>