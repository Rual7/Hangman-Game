<Window x:Class="Hangman_Game.Views.GameWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Hangman Game"
        Height="760"
        Width="1280"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Background="#120808">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>

        <SolidColorBrush x:Key="AppBg" Color="#120808"/>
        <SolidColorBrush x:Key="MenuBg" Color="#1A0D0D"/>
        <SolidColorBrush x:Key="MenuHoverBg" Color="#342020"/>
        <SolidColorBrush x:Key="GoldBrush" Color="#F2C979"/>
        <SolidColorBrush x:Key="GoldBorderBrush" Color="#D18A2C"/>
        <SolidColorBrush x:Key="MutedGoldBrush" Color="#B99A62"/>
        <SolidColorBrush x:Key="SeparatorBrush" Color="#6E3E17"/>
        <SolidColorBrush x:Key="CheckGreenBrush" Color="#6BE16B"/>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource GoldBrush}"/>
        </Style>

        <Style TargetType="Button">
            <Setter Property="Foreground" Value="{StaticResource GoldBrush}"/>
            <Setter Property="Background" Value="#2A1B1B"/>
            <Setter Property="BorderBrush" Value="{StaticResource GoldBorderBrush}"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="Margin" Value="6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#3A2525"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#E8AA44"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#1B1010"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#BA6F12"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Background" Value="#221515"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#705A35"/>
                                <Setter Property="Foreground" Value="#9A8358"/>
                                <Setter Property="Opacity" Value="0.75"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="KeyboardButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Width" Value="42"/>
            <Setter Property="Height" Value="42"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="Padding" Value="0"/>
        </Style>

        <Style TargetType="Menu">
            <Setter Property="Background" Value="{StaticResource MenuBg}"/>
            <Setter Property="Foreground" Value="{StaticResource GoldBrush}"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Padding" Value="6,0"/>
            <Setter Property="BorderBrush" Value="{StaticResource SeparatorBrush}"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
        </Style>

        <Style x:Key="TopLevelMenuItemStyle" TargetType="MenuItem">
            <Setter Property="Foreground" Value="{StaticResource GoldBrush}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="14,6"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="MenuItem">
                        <Grid>
                            <Border x:Name="TopBorder"
                                    Background="{TemplateBinding Background}"
                                    Padding="{TemplateBinding Padding}"
                                    BorderThickness="0">
                                <ContentPresenter ContentSource="Header"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                            </Border>

                            <Border x:Name="BottomAccent"
                                    VerticalAlignment="Bottom"
                                    Height="2"
                                    Background="{StaticResource GoldBorderBrush}"
                                    Visibility="Collapsed"/>

                            <Popup x:Name="PART_Popup"
                                   Placement="Bottom"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   IsOpen="{Binding IsSubmenuOpen, RelativeSource={RelativeSource TemplatedParent}}"
                                   PopupAnimation="Fade">
                                <Border Background="#140909"
                                        BorderBrush="{StaticResource GoldBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="4"
                                        Padding="0">
                                    <StackPanel IsItemsHost="True" MinWidth="180"/>
                                </Border>
                            </Popup>
                        </Grid>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="TopBorder" Property="Background" Value="#2A1212"/>
                                <Setter TargetName="BottomAccent" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="IsSubmenuOpen" Value="True">
                                <Setter TargetName="TopBorder" Property="Background" Value="#311818"/>
                                <Setter TargetName="BottomAccent" Property="Visibility" Value="Visible"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SubMenuItemStyle" TargetType="MenuItem">
            <Setter Property="Foreground" Value="{StaticResource GoldBrush}"/>
            <Setter Property="Background" Value="#180C0C"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="MenuItem">
                        <Grid SnapsToDevicePixels="True">
                            <Border x:Name="ItemBorder"
                                    Background="{TemplateBinding Background}"
                                    BorderThickness="0">
                                <Grid Height="{TemplateBinding Height}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="42"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="90"/>
                                        <ColumnDefinition Width="20"/>
                                    </Grid.ColumnDefinitions>

                                    <Grid Grid.Column="0"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center">
                                        <Border x:Name="CheckBoxBorder"
                                                Width="20"
                                                Height="20"
                                                Background="#241313"
                                                BorderBrush="{StaticResource GoldBorderBrush}"
                                                BorderThickness="1.5"
                                                CornerRadius="4"
                                                Visibility="Collapsed"/>
                                        <TextBlock x:Name="CheckMark"
                                                   Text="✔"
                                                   FontSize="14"
                                                   FontWeight="Bold"
                                                   Foreground="{StaticResource CheckGreenBrush}"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   Visibility="Collapsed"/>
                                    </Grid>

                                    <ContentPresenter Grid.Column="1"
                                                      ContentSource="Header"
                                                      VerticalAlignment="Center"
                                                      Margin="0,0,10,0"/>

                                    <TextBlock x:Name="GestureText"
                                               Grid.Column="2"
                                               Text="{TemplateBinding InputGestureText}"
                                               Foreground="{StaticResource MutedGoldBrush}"
                                               VerticalAlignment="Center"
                                               HorizontalAlignment="Right"
                                               FontSize="12"
                                               Margin="0,0,12,0"/>

                                    <Path x:Name="SubmenuArrow"
                                          Grid.Column="3"
                                          Margin="0,0,10,0"
                                          VerticalAlignment="Center"
                                          HorizontalAlignment="Center"
                                          Stroke="{StaticResource MutedGoldBrush}"
                                          StrokeThickness="2"
                                          Data="M 0 0 L 6 5 L 0 10"
                                          Visibility="Collapsed"/>
                                </Grid>
                            </Border>

                            <Popup x:Name="PART_Popup"
                                   Placement="Right"
                                   HorizontalOffset="-2"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   IsOpen="{Binding IsSubmenuOpen, RelativeSource={RelativeSource TemplatedParent}}"
                                   PopupAnimation="Fade">
                                <Border Background="#140909"
                                        BorderBrush="{StaticResource GoldBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="4"
                                        Padding="0">
                                    <StackPanel IsItemsHost="True"
                                                MinWidth="190"
                                                KeyboardNavigation.DirectionalNavigation="Cycle"/>
                                </Border>
                            </Popup>
                        </Grid>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{StaticResource MenuHoverBg}"/>
                            </Trigger>

                            <Trigger Property="IsSubmenuOpen" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#2B1717"/>
                            </Trigger>

                            <Trigger Property="IsCheckable" Value="True">
                                <Setter TargetName="CheckBoxBorder" Property="Visibility" Value="Visible"/>
                            </Trigger>

                            <Trigger Property="Role" Value="SubmenuHeader">
                                <Setter TargetName="SubmenuArrow" Property="Visibility" Value="Visible"/>
                            </Trigger>

                            <Trigger Property="Role" Value="SubmenuItem">
                                <Setter TargetName="SubmenuArrow" Property="Visibility" Value="Collapsed"/>
                            </Trigger>

                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsCheckable" Value="True"/>
                                    <Condition Property="IsChecked" Value="True"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="CheckMark" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="CheckBoxBorder" Property="Background" Value="#2E1E1E"/>
                                <Setter TargetName="ItemBorder" Property="Background" Value="#221616"/>
                            </MultiTrigger>

                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#7D6A46"/>
                                <Setter TargetName="ItemBorder" Property="Opacity" Value="0.7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Separator">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Separator">
                        <Border Height="0" Background="Transparent"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="LevelBoxStyle" TargetType="Border">
            <Setter Property="Width" Value="34"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="Margin" Value="5,0"/>
            <Setter Property="BorderBrush" Value="{StaticResource GoldBorderBrush}"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Background" Value="#241919"/>
            <Setter Property="CornerRadius" Value="6"/>
        </Style>
    </Window.Resources>

    <Window.InputBindings>
        <KeyBinding Key="N" Modifiers="Control" Command="{Binding Menu.NewGameCommand}" />
        <KeyBinding Key="S" Modifiers="Control" Command="{Binding Menu.SaveGameCommand}" />
        <KeyBinding Key="T" Modifiers="Control" Command="{Binding Menu.StatisticsCommand}" />
        <KeyBinding Key="Escape" Command="{Binding Menu.CancelCommand}" />
        <KeyBinding Key="F1" Command="{Binding Menu.AboutCommand}" />
    </Window.InputBindings>

    <DockPanel Background="{StaticResource AppBg}">
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="File" Style="{StaticResource TopLevelMenuItemStyle}">
                <MenuItem Header="New Game"
                          Style="{StaticResource SubMenuItemStyle}"
                          InputGestureText="Ctrl+N"
                          Command="{Binding Menu.NewGameCommand}" />

                <MenuItem Header="Open Game"
                          Style="{StaticResource SubMenuItemStyle}"
                          ItemsSource="{Binding SavedGamesMenuItems}"
                          IsEnabled="{Binding HasSavedGames}">
                    <MenuItem.ItemContainerStyle>
                        <Style TargetType="MenuItem" BasedOn="{StaticResource SubMenuItemStyle}">
                            <Setter Property="Header" Value="{Binding Header}" />
                            <Setter Property="Command" Value="{Binding Command}" />
                            <Setter Property="CommandParameter" Value="{Binding CommandParameter}" />
                        </Style>
                    </MenuItem.ItemContainerStyle>
                </MenuItem>

                <MenuItem Header="Save Game"
                          Style="{StaticResource SubMenuItemStyle}"
                          InputGestureText="Ctrl+S"
                          Command="{Binding Menu.SaveGameCommand}" />

                <MenuItem Header="Statistics"
                          Style="{StaticResource SubMenuItemStyle}"
                          InputGestureText="Ctrl+T"
                          Command="{Binding Menu.StatisticsCommand}" />

                <MenuItem Header="Cancel"
                          Style="{StaticResource SubMenuItemStyle}"
                          InputGestureText="Esc"
                          Command="{Binding Menu.CancelCommand}" />
            </MenuItem>

            <MenuItem Header="Categories"
                      Style="{StaticResource TopLevelMenuItemStyle}"
                      ItemsSource="{Binding CategoryMenuItems}">
                <MenuItem.ItemContainerStyle>
                    <Style TargetType="MenuItem" BasedOn="{StaticResource SubMenuItemStyle}">
                        <Setter Property="Header" Value="{Binding Header}" />
                        <Setter Property="IsCheckable" Value="True" />
                        <Setter Property="IsChecked" Value="{Binding IsChecked}" />
                        <Setter Property="Command" Value="{Binding Command}" />
                        <Setter Property="CommandParameter" Value="{Binding CommandParameter}" />
                    </Style>
                </MenuItem.ItemContainerStyle>
            </MenuItem>

            <MenuItem Header="Help" Style="{StaticResource TopLevelMenuItemStyle}">
                <MenuItem Header="About"
                          Style="{StaticResource SubMenuItemStyle}"
                          InputGestureText="F1"
                          Command="{Binding Menu.AboutCommand}" />
            </MenuItem>
        </Menu>

        <Grid Margin="16,18,20,20">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="4.8*"/>
                <ColumnDefinition Width="4.7*"/>
                <ColumnDefinition Width="3.8*"/>
            </Grid.ColumnDefinitions>

            <!-- Gallows -->
            <Grid Grid.Row="0" Grid.Column="0" Margin="-115,-225,0,0">
                <Image Source="{Binding HangmanImagePath}"
                       Width="600"
                       Height="600"
                       Stretch="Uniform"
                       HorizontalAlignment="Left"
                       VerticalAlignment="Center"/>
            </Grid>

            <!-- Center gameplay -->
            <Grid Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="3">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- WORD -->
                <TextBlock Grid.Row="0"
                           Text="{Binding MaskedWord}"
                           FontSize="46"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           TextAlignment="Center"
                           Foreground="{StaticResource GoldBrush}"/>

                <!-- START BUTTON -->
                <Button Grid.Row="1"
                        Content="START"
                        Width="140"
                        Height="44"
                        FontSize="18"
                        FontWeight="Bold"
                        HorizontalAlignment="Center"
                        Margin="0,20,0,0"
                        Command="{Binding Menu.NewGameCommand}">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasActiveSession}" Value="False">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

                <!-- KEYBOARD -->
                <StackPanel Grid.Row="2"
                            HorizontalAlignment="Center"
                            Margin="0,20,0,0">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Visible"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasActiveSession}" Value="False">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>

                    <!-- ROW 1 -->
                    <ItemsControl ItemsSource="{Binding KeyboardRow1}" HorizontalAlignment="Center">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Content="{Binding}"
                                        Style="{StaticResource KeyboardButtonStyle}"
                                        Command="{Binding DataContext.GuessLetterCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                        CommandParameter="{Binding}"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- ROW 2 -->
                    <ItemsControl ItemsSource="{Binding KeyboardRow2}" HorizontalAlignment="Center" Margin="0,4,0,0">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Content="{Binding}"
                                        Style="{StaticResource KeyboardButtonStyle}"
                                        Command="{Binding DataContext.GuessLetterCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                        CommandParameter="{Binding}"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- ROW 3 -->
                    <ItemsControl ItemsSource="{Binding KeyboardRow3}" HorizontalAlignment="Center" Margin="0,4,0,0">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Content="{Binding}"
                                        Style="{StaticResource KeyboardButtonStyle}"
                                        Command="{Binding DataContext.GuessLetterCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                        CommandParameter="{Binding}"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Grid>

            <!-- Right panel -->
            <Grid Grid.Row="0" Grid.Column="2" Margin="8,8,0,0">
                <StackPanel HorizontalAlignment="Right">
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                Margin="0,0,0,14">
                        <StackPanel VerticalAlignment="Center"
                                    Margin="0,0,10,0">
                            <TextBlock Text="{Binding UsernameDisplay}"
                                       FontSize="18"
                                       FontWeight="Bold"
                                       HorizontalAlignment="Right"
                                       Foreground="{StaticResource GoldBrush}"/>
                            <TextBlock Text="{Binding UserLevelDisplay}"
                                       FontSize="14"
                                       HorizontalAlignment="Right"/>
                        </StackPanel>

                        <Rectangle Width="62"
                                   Height="62"
                                   RadiusX="10"
                                   RadiusY="10"
                                   Stroke="{StaticResource GoldBorderBrush}"
                                   StrokeThickness="2">
                            <Rectangle.Fill>
                                <ImageBrush ImageSource="{Binding UserAvatarPath}"
                                            Stretch="UniformToFill"
                                            AlignmentX="Center"
                                            AlignmentY="Center"/>
                            </Rectangle.Fill>
                        </Rectangle>
                    </StackPanel>

                    <!-- Timer fara border -->
                    <Grid Width="380"
                          Height="194"
                          HorizontalAlignment="Right"
                          ClipToBounds="True"
                          Margin="0,4,0,0">
                        <Grid.Background>
                            <ImageBrush ImageSource="{Binding TimerFrameImagePath}"
                                        Stretch="Fill"
                                        AlignmentX="Center"
                                        AlignmentY="Center"
                                        ViewboxUnits="RelativeToBoundingBox"
                                        Viewbox="0.02,0.092,0.84,0.79"/>
                        </Grid.Background>

                        <TextBlock Text="{Binding TimeDisplay}"
                                   FontSize="44"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Margin="40,4,0,0"
                                   Foreground="{StaticResource GoldBrush}"/>
                    </Grid>

                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                Margin="0,16,0,0">
                        <Border Style="{StaticResource LevelBoxStyle}">
                            <Grid>
                                <TextBlock Text="✔"
                                           FontSize="20"
                                           FontWeight="Bold"
                                           Foreground="{StaticResource CheckGreenBrush}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Visibility="{Binding IsLevel1Completed, Converter={StaticResource BoolToVisibilityConverter}}"/>

                                <TextBlock Text="✖"
                                           FontSize="20"
                                           FontWeight="Bold"
                                           Foreground="Red"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Visibility="{Binding IsLevel1Failed, Converter={StaticResource BoolToVisibilityConverter}}"/>
                            </Grid>
                        </Border>
                        

                        <Border Style="{StaticResource LevelBoxStyle}">
                            <Grid>
                                <TextBlock Text="✔"
                                           FontSize="20"
                                           FontWeight="Bold"
                                           Foreground="{StaticResource CheckGreenBrush}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Visibility="{Binding IsLevel2Completed, Converter={StaticResource BoolToVisibilityConverter}}"/>

                                <TextBlock Text="✖"
                                           FontSize="20"
                                           FontWeight="Bold"
                                           Foreground="Red"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Visibility="{Binding IsLevel2Failed, Converter={StaticResource BoolToVisibilityConverter}}"/>
                            </Grid>
                         </Border>

                        <Border Style="{StaticResource LevelBoxStyle}">
                            <Grid>
                                <TextBlock Text="✔"
                                           FontSize="20"
                                           FontWeight="Bold"
                                           Foreground="{StaticResource CheckGreenBrush}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Visibility="{Binding IsLevel3Completed, Converter={StaticResource BoolToVisibilityConverter}}"/>

                                <TextBlock Text="✖"
                                           FontSize="20"
                                           FontWeight="Bold"
                                           Foreground="Red"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Visibility="{Binding IsLevel3Failed, Converter={StaticResource BoolToVisibilityConverter}}"/>
                            </Grid>
                        </Border>
                    </StackPanel>
                </StackPanel>
            </Grid>

            <!-- Bottom left status -->
            <Grid Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Margin="8,18,0,0">
                <StackPanel HorizontalAlignment="Left" VerticalAlignment="Bottom">
                    <TextBlock Text="{Binding HintText}"
                               FontSize="18"
                               FontWeight="Bold"
                               Foreground="{StaticResource GoldBrush}"/>

                    <TextBlock Text="{Binding StatusMessage}"
                               FontSize="18"
                               FontWeight="Bold"
                               Margin="0,8,0,0"
                               TextWrapping="Wrap"
                               MaxWidth="760"/>
                </StackPanel>
            </Grid>

            <!-- Exit -->
            <Grid Grid.Row="1" Grid.Column="2" Margin="0,16,0,0">
                <Button Content="Exit"
                        Width="120"
                        Height="44"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Bottom"
                        Command="{Binding Menu.CancelCommand}"/>
            </Grid>
        </Grid>
    </DockPanel>
</Window>